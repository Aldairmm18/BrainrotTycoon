			total = total + cfg.cashPerSec
		end
	end
	return total
end

-- ─── Rebirth ─────────────────────────────────────────────────────────────────

function BrainrotData.Rebirth(userId)
	local d = _data[userId]
	if not d then return false end
	if #d.brainrots < 10 then return false end
	d.cash      = 0
	d.brainrots = {}
	d.rebirths  = d.rebirths + 1
	return true
